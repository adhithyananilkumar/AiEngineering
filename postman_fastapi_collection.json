{
  "info": {
    "name": "FastAPI - Simple Tests",
    "_postman_id": "a1b2c3d4-FASTAPI-SIMPLE",
    "description": "A small Postman collection to test the FastAPI app in main.py",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Root - GET /",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Has message\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('message');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create Item - POST /items",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sample item\",\n  \"description\": \"A test item\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/items", "host": ["{{baseUrl}}"], "path": ["items"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Response has id and name\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('name');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "List Items - GET /items",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/items", "host": ["{{baseUrl}}"], "path": ["items"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Response is array\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(Array.isArray(json)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Item - GET /items/:item_id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/items/:item_id",
          "host": ["{{baseUrl}}"],
          "path": ["items", ":item_id"],
          "variable": [ { "key": "item_id", "value": "1" } ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200 or 404 (if not found)\", function () {",
              "  pm.expect(pm.response.code === 200 || pm.response.code === 404).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Item - PUT /items/:item_id",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated name\",\n  \"description\": \"Updated desc\"\n}" },
        "url": { "raw": "{{baseUrl}}/items/:item_id", "host": ["{{baseUrl}}"], "path": ["items", ":item_id"], "variable": [ { "key": "item_id", "value": "1" } ] }
      },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test(\"Status is 200 or 404\", function () { pm.expect(pm.response.code === 200 || pm.response.code === 404).to.be.true; });" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Delete Item - DELETE /items/:item_id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/items/:item_id", "host": ["{{baseUrl}}"], "path": ["items", ":item_id"], "variable": [ { "key": "item_id", "value": "1" } ] }
      },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test(\"Status is 200 or 404\", function () { pm.expect(pm.response.code === 200 || pm.response.code === 404).to.be.true; });" ], "type": "text/javascript" } } ]
    }
  ]
}
