{
  "info": {
    "name": "FastAPI - Student Management API",
    "_postman_id": "a1b2c3d4-FASTAPI-SIMPLE",
    "description": "Beginner CRUD tests for the Student Management API (/students)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "default"
    },
    {
      "key": "student_id",
      "value": "",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Root - GET /",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Has message\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('message');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create Student - POST /students",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Akhil\",\n  \"age\": 20\n}"
        },
        "url": { "raw": "{{baseUrl}}/students", "host": ["{{baseUrl}}"], "path": ["students"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201\", function () { pm.response.to.have.status(201); });",
              "pm.test(\"Response has id, name, age\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('name');",
              "  pm.expect(json).to.have.property('age');",
              "  // Save id for next requests (GET/PUT/DELETE)",
              "  pm.collectionVariables.set('student_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "List Students - GET /students?skip=0&limit=10",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/students?skip=0&limit=10", "host": ["{{baseUrl}}"], "path": ["students"], "query": [ { "key": "skip", "value": "0" }, { "key": "limit", "value": "10" } ] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Response is array\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(Array.isArray(json)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Student - GET /students/:student_id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/students/{{student_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["students", "{{student_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Response has id, name, age\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('name');",
              "  pm.expect(json).to.have.property('age');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Student - PUT /students/:student_id",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Akhil Updated\",\n  \"age\": 21\n}" },
        "url": { "raw": "{{baseUrl}}/students/{{student_id}}", "host": ["{{baseUrl}}"], "path": ["students", "{{student_id}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Updated response has id\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete Student - DELETE /students/:student_id",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/students/{{student_id}}", "host": ["{{baseUrl}}"], "path": ["students", "{{student_id}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Has message\", function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.property('message');",
              "});",
              "// Optional: clear saved id after delete",
              "pm.collectionVariables.unset('student_id');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
